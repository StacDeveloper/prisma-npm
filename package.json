{
  "name": "prisma-pg-toolkit",
  "version": "1.0.1",
  "description": "Joins (INNER/LEFT/RIGHT/FULL OUTER/CROSS) and locking (pessimistic/optimistic) helpers for Prisma",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "tsx src/testing/test-joins.ts",
    "prisma:migrate": "npx prisma migrate dev --name init",
    "prisma:generate": "npx prisma generate",
    "seed": "tsx prisma/seed.ts",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run --no-file-parallelism"
  },
  "keywords": [
    "prisma",
    "joins",
    "locking",
    "optimistic-locking",
    "pessimistic-locking"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StacDeveloper/prisma-npm.git"
  },
  "homepage": "https://github.com/StacDeveloper/prisma-npm.git#readme",
  "bugs": {
    "url": "https://github.com/StacDeveloper/prisma-npm.git/issues"
  },
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "@prisma/client": ">=5.0.0"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.3",
    "@types/node": "^22.0.0",
    "dotenv": "^17.4.2",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  }
}